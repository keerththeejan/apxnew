# Leave empty to auto-detect for both localhost and live domain.
APP_BASE_URL=
APP_TIMEZONE=UTC

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=apxp
DB_USERNAME=root
DB_PASSWORD=1234
# Optional on hosting (can override DB_*):
# DB_URL=
# DATABASE_URL=
DB_CONNECT_TIMEOUT=10
DB_SSL_CA=
DB_SSL_VERIFY=1

APP_LOCALE=en

# Outgoing mail (SMTP SSL, port 465 — mail.apx.lk). Quote MAIL_PASSWORD if it contains #.
MAIL_HOST=mail.apx.lk
MAIL_PORT=465
MAIL_USERNAME=info@apx.lk
MAIL_PASSWORD="Apx@2026#@!"
MAIL_FROM_ADDRESS=info@apx.lk
MAIL_FROM_NAME=APX
# If TLS verification fails on Windows/WAMP, set to 0 (not recommended for production)
MAIL_SSL_VERIFY=1
