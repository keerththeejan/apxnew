            <h1 class="h3 fw-bold mb-1">Booking received</h1>
            <p class="text-secondary mb-3">We’ll contact you shortly with the next steps.</p>

            <div class="border rounded-3 p-3">
              <div class="row g-2">
                <div class="col-12 col-md-6"><div class="text-secondary small">Reference</div><div class="fw-bold"><?= e((string) ($booking['code'] ?? '')) ?></div></div>
