<?php

declare(strict_types=1);

$s = $settings ?? [];
$v = static function (string $key, string $default = '') use ($s): string {
    return (string) ($s[$key] ?? $default);
};

/** Prefer DB setting; if empty, show .env value for display (save copies into DB). */
$ve = static function (string $key, string $envKey, string $default = '') use ($v): string {
    $db = trim($v($key, ''));
    if ($db !== '') {
        return $db;
    }
    $e = env($envKey, $default);

    return trim((string) ($e !== null && $e !== '' ? $e : $default));
};

$mailSsl = $v('mail_ssl_verify', '');
if ($mailSsl === '') {
    $ev = strtolower(trim((string) env('MAIL_SSL_VERIFY', '1')));
    $mailSsl = in_array($ev, ['0', 'false', 'no', 'off'], true) ? '0' : '1';
} else {
    $mailSsl = $mailSsl === '1' ? '1' : '0';
}

$mailFromDisplay = trim($v('mail_from_address', ''));
if ($mailFromDisplay === '') {
    $mailFromDisplay = trim((string) (env('MAIL_FROM_ADDRESS', '') ?? ''));
}
if ($mailFromDisplay === '') {
    $mailFromDisplay = trim((string) (env('MAIL_FROM', '') ?? ''));
}

$mailTestTo = trim($v('mail_test_to', ''));
if ($mailTestTo === '') {
    $mailTestTo = 'keerththeejan@gmail.com';
}

$socialRows = [];
$rawSocial = $v('social_links_json', '');
if ($rawSocial !== '') {
    $decoded = json_decode($rawSocial, true);
    if (is_array($decoded)) {
        foreach ($decoded as $row) {
            if (!is_array($row)) {
                continue;
            }
            $socialRows[] = [
                'label' => (string) ($row['label'] ?? ''),
                'url' => (string) ($row['url'] ?? ''),
            ];
        }
    }
}
if ($socialRows === []) {
    $socialRows = [
        ['label' => 'Facebook', 'url' => $v('social_facebook', '#')],
        ['label' => 'Instagram', 'url' => $v('social_instagram', '#')],
        ['label' => 'YouTube', 'url' => $v('social_youtube', '#')],
        ['label' => 'TikTok', 'url' => $v('social_tiktok', '#')],
    ];
}
while (count($socialRows) < 6) {
    $socialRows[] = ['label' => '', 'url' => ''];
}

$logoPreview = $v('site_logo_path', '/images/logo.png');

