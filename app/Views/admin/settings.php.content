  <script>
  (function(){
    var form = document.getElementById('settingsAllForm');
    var prev = document.getElementById('logoPreviewImg');
    var fin = form ? form.querySelector('input[name="logo_file"]') : null;
    if (fin && prev) {
      fin.addEventListener('change', function(){
        var f = fin.files && fin.files[0];
        if (!f) return;
        var r = new FileReader();
        r.onload = function(){ prev.src = r.result; };
        r.readAsDataURL(f);
      });
    }
    var btnMail = document.getElementById('btnMailTest');
    var mailTo = document.getElementById('mailTestTo');
    var flashEl = document.getElementById('settingsAjaxFlash');
    if (btnMail && form && mailTo) {
      btnMail.addEventListener('click', function(){
        var tokenInp = form.querySelector('input[name="_token"]');
        if (!tokenInp) return;
        btnMail.disabled = true;
        var fd = new URLSearchParams();
        fd.set('_token', tokenInp.value);
        fd.set('to', mailTo.value.trim());
        fetch('<?= e(base_url('/admin/settings/email/test')) ?>', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
          body: fd.toString()
        }).then(function(res){ return res.json().then(function(j){ return { res: res, j: j }; }); })
        .then(function(x){
          if (!flashEl) return;
          var ok = x.j && x.j.ok;
          var msg = (x.j && x.j.message) ? String(x.j.message) : 'Request failed';
          var esc = document.createElement('div');
          esc.textContent = msg;
          flashEl.innerHTML = '<div class="alert alert-' + (ok ? 'success' : 'danger') + ' mb-0">' + esc.innerHTML + '</div>';
          flashEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }).catch(function(){
          if (flashEl) flashEl.innerHTML = '<div class="alert alert-danger mb-0">Network error.</div>';
        }).finally(function(){ btnMail.disabled = false; });
      });
    }
  })();
  </script>
</template>
